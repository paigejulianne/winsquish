<Window x:Class="WinSquish.Views.CompressOptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Compression options"
        Icon="pack://application:,,,/assets/winsquish.ico"
        Width="420" SizeToContent="Height"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Ideal" UseLayoutRounding="True">

  <Window.Resources>
    <!-- Plain dialog buttons (the app's ToolButton is icon-over-caption) -->
    <Style x:Key="DialogButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
      <Setter Property="Background" Value="{StaticResource Surface}" />
      <Setter Property="Padding" Value="18,7" />
      <Setter Property="MinWidth" Value="84" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                    BorderBrush="{StaticResource BorderStrong}" BorderThickness="1"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverFill}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="bd" Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DialogButtonAccent" TargetType="Button" BasedOn="{StaticResource DialogButton}">
      <Setter Property="Foreground" Value="{StaticResource TextOnAccent}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="bd" Background="{StaticResource Accent}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                TextElement.Foreground="{StaticResource TextOnAccent}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentHover}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Padding" Value="8,6" />
      <Setter Property="Background" Value="{StaticResource Surface}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderStrong}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style x:Key="FieldHint" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource TextSecondary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
  </Window.Resources>

  <StackPanel Margin="22,20">
    <TextBlock Text="Compression options" FontSize="16" FontWeight="SemiBold" />
    <TextBlock x:Name="SourceLine" Foreground="{StaticResource TextSecondary}"
               Margin="0,3,0,0" TextTrimming="CharacterEllipsis" />

    <!-- Block size -->
    <TextBlock Text="Block size (MiB)" Style="{StaticResource FieldLabel}" Margin="0,18,0,4" />
    <TextBox x:Name="BlockSizeBox" Text="16" MaxLength="7"
             PreviewTextInput="OnDigitsOnly" />
    <TextBlock Style="{StaticResource FieldHint}"
               Text="Larger blocks compress a little tighter; smaller blocks parallelize better and seek faster. Default is 16 MiB." />

    <!-- Threads -->
    <TextBlock Text="Threads" Style="{StaticResource FieldLabel}" Margin="0,16,0,4" />
    <TextBox x:Name="ThreadsBox" Text="0" MaxLength="4"
             PreviewTextInput="OnDigitsOnly" />
    <TextBlock x:Name="ThreadsHint" Style="{StaticResource FieldHint}" />

    <!-- Buttons -->
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
      <Button Content="Cancel" Style="{StaticResource DialogButton}" IsCancel="True"
              Click="OnCancel" />
      <Button Content="Compress" Style="{StaticResource DialogButtonAccent}" IsDefault="True"
              Click="OnCompress" />
    </StackPanel>
  </StackPanel>
</Window>
