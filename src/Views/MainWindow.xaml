<Window x:Class="WinSquish.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:WinSquish.ViewModels"
        xmlns:models="clr-namespace:WinSquish.Models"
        Title="{Binding WindowTitle}"
        Icon="pack://application:,,,/assets/winsquish.ico"
        Height="680" Width="1040" MinHeight="440" MinWidth="720"
        Background="{StaticResource WindowBg}"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="OnDrop" DragOver="OnDragOver"
        FontFamily="Segoe UI Variable, Segoe UI" FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

  <Window.InputBindings>
    <KeyBinding Key="O" Modifiers="Control" Command="{Binding OpenCommand}" />
    <KeyBinding Key="N" Modifiers="Control" Command="{Binding NewCommand}" />
    <KeyBinding Key="E" Modifiers="Control" Command="{Binding ExtractSelectedCommand}" />
    <KeyBinding Key="F5" Command="{Binding RefreshCommand}" />
    <KeyBinding Key="Back" Command="{Binding UpCommand}" />
  </Window.InputBindings>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />   <!-- command bar   -->
      <RowDefinition Height="Auto" />   <!-- breadcrumb     -->
      <RowDefinition Height="*" />      <!-- content        -->
      <RowDefinition Height="Auto" />   <!-- status bar     -->
    </Grid.RowDefinitions>

    <!-- ============ Command bar ============ -->
    <Border Grid.Row="0" Background="{StaticResource Chrome}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
      <StackPanel Orientation="Horizontal" Margin="8,6">
        <Button Style="{StaticResource ToolButtonAccent}" Tag="&#xE8E5;" Content="Open"
                Command="{Binding OpenCommand}" ToolTip="Open a SQUISH archive (Ctrl+O)" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE710;" Content="New"
                Command="{Binding NewCommand}" ToolTip="Create an archive from a folder (Ctrl+N)" />
        <Separator Margin="6,4" Background="{StaticResource Border}" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE896;" Content="Extract"
                Command="{Binding ExtractSelectedCommand}" ToolTip="Extract selected items (Ctrl+E)" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xF12B;" Content="Extract All"
                Command="{Binding ExtractAllCommand}" ToolTip="Extract the entire archive" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE8A7;" Content="Open"
                Command="{Binding OpenItemCommand}" ToolTip="Open the selected file with its default app" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE792;" Content="Save As"
                Command="{Binding SaveAsCommand}" ToolTip="Save the selected file to disk" />
        <Separator Margin="6,4" Background="{StaticResource Border}" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE72C;" Content="Refresh"
                Command="{Binding RefreshCommand}" ToolTip="Reload the archive (F5)" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE8BB;" Content="Close"
                Command="{Binding CloseArchiveCommand}" ToolTip="Close the archive" />
        <Button Style="{StaticResource ToolButton}" Tag="&#xE946;" Content="About"
                Command="{Binding AboutCommand}" ToolTip="About WinSquish" />
      </StackPanel>
    </Border>

    <!-- ============ Breadcrumb ============ -->
    <Border Grid.Row="1" Background="{StaticResource Surface}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1"
            Visibility="{Binding IsArchiveOpen, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal" Margin="10,5" VerticalAlignment="Center">
        <Button Style="{StaticResource CrumbButton}" Command="{Binding UpCommand}"
                ToolTip="Up one level (Backspace)" Padding="6,3">
          <TextBlock Text="&#xE74A;" FontFamily="{StaticResource IconFont}" FontSize="14" />
        </Button>
        <Border Width="1" Background="{StaticResource Border}" Margin="6,3" />
        <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="15"
                   Foreground="{StaticResource Accent}" VerticalAlignment="Center" Margin="2,0,4,0" />
        <StackPanel x:Name="CrumbPanel" Orientation="Horizontal" VerticalAlignment="Center" />
      </StackPanel>
    </Border>

    <!-- ============ Content ============ -->
    <Grid Grid.Row="2">
      <!-- Split view: folder tree | details -->
      <Grid Visibility="{Binding IsArchiveOpen, Converter={StaticResource BoolToVis}}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="240" MinWidth="150" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" MinWidth="320" />
        </Grid.ColumnDefinitions>

        <!-- Folder tree -->
        <Border Grid.Column="0" Background="{StaticResource SidebarBg}"
                BorderBrush="{StaticResource Border}" BorderThickness="0,0,1,0">
          <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="FOLDERS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondary}" Margin="14,12,10,6" />
            <TreeView x:Name="FolderTree" ItemsSource="{Binding TreeRoots}"
                      SelectedItemChanged="OnTreeSelectionChanged"
                      BorderThickness="0" Background="Transparent">
              <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                  <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                  <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                </Style>
              </TreeView.ItemContainerStyle>
              <TreeView.Resources>
                <HierarchicalDataTemplate DataType="{x:Type models:ArchiveNode}"
                                          ItemsSource="{Binding Folders}">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE8B7;" FontFamily="{StaticResource IconFont}" FontSize="15"
                               Foreground="{StaticResource Accent}" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Name}" Margin="7,0,0,0" VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                  </StackPanel>
                </HierarchicalDataTemplate>
              </TreeView.Resources>
            </TreeView>
          </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                      Background="Transparent" ResizeBehavior="PreviousAndNext" />

        <!-- Details list -->
        <Border Grid.Column="2" Background="{StaticResource Surface}">
          <Grid>
            <ListView x:Name="DetailsView" Style="{StaticResource DetailsList}"
                      ItemsSource="{Binding Items}" Margin="6,4"
                      SelectionMode="Extended"
                      SelectionChanged="OnDetailsSelectionChanged"
                      MouseDoubleClick="OnDetailsDoubleClick"
                      KeyDown="OnDetailsKeyDown"
                      PreviewMouseLeftButtonDown="OnDetailsPreviewLeftDown"
                      MouseMove="OnDetailsMouseMove">
              <ListView.ContextMenu>
                <ContextMenu>
                  <MenuItem Header="Open" InputGestureText="Enter"
                            Command="{Binding PlacementTarget.DataContext.OpenItemCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                  <MenuItem Header="Extract…" InputGestureText="Ctrl+E"
                            Command="{Binding PlacementTarget.DataContext.ExtractSelectedCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                  <MenuItem Header="Save As…"
                            Command="{Binding PlacementTarget.DataContext.SaveAsCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                  <Separator />
                  <MenuItem Header="Select All" InputGestureText="Ctrl+A"
                            Command="{Binding PlacementTarget.DataContext.SelectAllCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                  <MenuItem Header="Extract All"
                            Command="{Binding PlacementTarget.DataContext.ExtractAllCommand,
                                      RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                </ContextMenu>
              </ListView.ContextMenu>
              <ListView.View>
                <GridView ColumnHeaderContainerStyle="{StaticResource HeaderStyle}">
                  <GridViewColumn Header="Name" Width="330">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                          <TextBlock Text="{Binding Converter={StaticResource NodeGlyph}}"
                                     FontFamily="{StaticResource IconFont}" FontSize="16"
                                     Foreground="{StaticResource Accent}" VerticalAlignment="Center" Width="22" />
                          <TextBlock Text="{Binding Name}" VerticalAlignment="Center"
                                     TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Type" Width="130">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource NodeType}}"
                                   Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Size" Width="100">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource NodeSize}}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Packed" Width="100">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding StoredSize, Converter={StaticResource Bytes}}"
                                   Foreground="{StaticResource TextSecondary}"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                  <GridViewColumn Header="Saved" Width="80">
                    <GridViewColumn.CellTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding Ratio, Converter={StaticResource Ratio}}"
                                   Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                   Margin="0,0,12,0" />
                      </DataTemplate>
                    </GridViewColumn.CellTemplate>
                  </GridViewColumn>
                </GridView>
              </ListView.View>
            </ListView>

            <!-- Empty folder hint -->
            <TextBlock Text="This folder is empty."
                       Foreground="{StaticResource TextSecondary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       IsHitTestVisible="False">
              <TextBlock.Style>
                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                  <Setter Property="Visibility" Value="Collapsed" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding Items.Count}" Value="0">
                      <Setter Property="Visibility" Value="Visible" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </TextBlock.Style>
            </TextBlock>
          </Grid>
        </Border>
      </Grid>

      <!-- ============ Empty / welcome state ============ -->
      <Border Background="{StaticResource WindowBg}"
              Visibility="{Binding IsArchiveOpen, Converter={StaticResource BoolToVisInv}}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="420">
          <TextBlock Text="&#xF12B;" FontFamily="{StaticResource IconFont}" FontSize="72"
                     Foreground="{StaticResource Accent}" HorizontalAlignment="Center" Opacity="0.9" />
          <TextBlock Text="WinSquish" FontSize="30" FontWeight="Light"
                     HorizontalAlignment="Center" Margin="0,14,0,2" />
          <TextBlock Text="A file-manager for SQUISH archives"
                     Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" />
          <TextBlock Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center"
                     TextAlignment="Center" Margin="0,22,0,18" TextWrapping="Wrap">
            Open a <Run FontWeight="SemiBold">.sqsh</Run> archive to browse it, or drag one
            onto this window. You can also compress a folder into a new archive.
          </TextBlock>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Style="{StaticResource ToolButtonAccent}" Tag="&#xE8E5;" Content="Open archive"
                    Command="{Binding OpenCommand}" Padding="18,10" />
            <Button Style="{StaticResource ToolButton}" Tag="&#xE710;" Content="New archive"
                    Command="{Binding NewCommand}" Padding="18,10" Margin="10,0,0,0" />
          </StackPanel>
          <Button Style="{StaticResource CrumbButton}" Command="{Binding AssociateCommand}"
                  HorizontalAlignment="Center" Margin="0,20,0,0" Padding="10,5"
                  ToolTip="Register .sqsh/.sq file types and the folder right-click menu for your account">
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE71B;" FontFamily="{StaticResource IconFont}" FontSize="13"
                         VerticalAlignment="Center" Margin="0,0,7,0" />
              <TextBlock Text="Make WinSquish the default for .sqsh files" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </StackPanel>
      </Border>

      <!-- ============ Busy overlay ============ -->
      <Border Background="#66000000"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
        <Border Background="{StaticResource Surface}" CornerRadius="10" Width="380"
                Padding="24,20" VerticalAlignment="Center" HorizontalAlignment="Center">
          <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.25" />
          </Border.Effect>
          <StackPanel>
            <TextBlock Text="{Binding BusyTitle}" FontWeight="SemiBold" TextWrapping="Wrap"
                       TextTrimming="CharacterEllipsis" />
            <ProgressBar Margin="0,14,0,0" Maximum="1" Value="{Binding Progress, Mode=OneWay}"
                         IsIndeterminate="{Binding ProgressIndeterminate}" />
            <TextBlock Text="Working… SQUISH trades CPU for a smaller archive."
                       Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,10,0,0" />
          </StackPanel>
        </Border>
      </Border>
    </Grid>

    <!-- ============ Status bar ============ -->
    <Border Grid.Row="3" Background="{StaticResource Chrome}"
            BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
      <Grid Margin="12,5">
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="{Binding Status}" Foreground="{StaticResource TextSecondary}"
                     TextTrimming="CharacterEllipsis" MaxWidth="620" />
          <TextBlock Text="{Binding SelectionSummary}" Foreground="{StaticResource TextSecondary}" />
        </StackPanel>
        <TextBlock Text="{Binding ArchiveSummary}" HorizontalAlignment="Right"
                   Foreground="{StaticResource TextSecondary}" FontWeight="SemiBold" />
      </Grid>
    </Border>
  </Grid>
</Window>
