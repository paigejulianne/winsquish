# Windows batch files must stay CRLF, or cmd.exe misparses them.
*.bat  text eol=crlf

# Keep the usual text files as LF in the repo, normalized on checkin.
*.cpp  text
*.h    text
*.rc   text
*.md   text
*.iss  text
*.ps1  text
*.yml  text
*.manifest text

# Binary assets — never normalize or diff as text.
*.dll  binary
*.lib  binary
*.exe  binary
*.ico  binary
*.png  binary
